      "source": [
        "# LangChain integration example\n",
        "\n",
        "This notebook shows how to wrap the `VottunComplianceClient` SDK as a LangChain `Tool`.\n",
        "\n",
        "- Certification runs through `POST /v1/certify`\n",
        "- The watermarking algorithm is **server-side** (SDK sends `watermark=True`)\n",
        "- Verification runs through `GET /v1/verify/{id_or_hash}`\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 1) Install prerequisites (pick versions compatible with your LangChain stack)\n",
        "# pip install vottun-compliance httpx\n",
        "# pip install langchain-core\n",
        "\n",
        "from vottun_compliance import VottunComplianceClient\n",
        "\n",
        "client = VottunComplianceClient()  # no API key => free testnet mode\n",
        "\n",
        "# 2) LangChain Tool wrapper\n",
        "from langchain_core.tools import Tool\n",
        "\n",
        "def certify_text(text: str, ai_system: str = \"gpt-4o\"):\n",
        "    return client.certify_content(content=text, ai_system=ai_system, watermark=True)\n",
        "\n",
        "certify_tool = Tool(\n",
        "    name=\"vottun_certify_content\",\n",
        "    description=\"Certify AI-generated text content and return the certificate response.\",\n",
        "    func=certify_text,\n",
        ")\n",
        "\n",
        "def verify_cert(cert_id: str):\n",
        "    return client.verify_certificate(cert_id)\n",
        "\n",
        "verify_tool = Tool(\n",
        "    name=\"vottun_verify_certificate\",\n",
        "    description=\"Verify a Vottun certificate by cert id (vtn_...) or content hash.\",\n",
        "    func=verify_cert,\n+        ")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 3) Use the tools directly (no LLM required)\n",
        "text = \"Hello world (example).\"\n",
        "\n",
        "cert = certify_tool.run(text)\n",
        "cert_id = cert.get(\"cert_id\") or cert.get(\"certificate_id\")\n",
        "\n",
        "print(\"cert_id:\", cert_id)\n",
        "\n",
        "if cert_id:\n",
        "    result = verify_tool.run(cert_id)\n",
        "    print(\"verify result:\")\n",
        "    print(result)\n",
        "else:\n",
        "    print(\"No cert id found in response.\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Notes\n",
        "\n",
        "1. If you want to run against localhost, pass `base_url='http://localhost:8000/api'` to `VottunComplianceClient`.\n",
        "2. For an Agent that decides when to certify/verify, connect these tools to your preferred LangChain agent/graph setup.\n"
      ]
    }
  ],
